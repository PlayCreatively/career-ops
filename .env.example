# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.5-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.5-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-thinking-exp
# GEMINI_MODEL=gemini-2.5-flash

# ── IGDB Studio Context (logo, previous games, founding) ─────────────────────
# Required for: node studio-info.mjs "Studio Name"  and  --board board enrichment
# Free, one-time setup:
#   1. Create a Twitch account + enable 2FA: https://dev.twitch.tv/
#   2. Register an application (any name; OAuth Redirect URL: http://localhost;
#      Category: Application Integration) → gives you a Client ID
#   3. On that app, click "New Secret" → gives you a Client Secret
#   4. Paste both below. IGDB uses these Twitch credentials directly.
# Docs: https://api-docs.igdb.com/#getting-started
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration
